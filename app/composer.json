{
    "name": "zaim/loan-api",
    "description": "Loan Application API built with Yii2",
    "type": "project",
    "license": "MIT",
    "repositories": [
        {
            "type": "composer",
            "url": "https://asset-packagist.org"
        }
    ],
    "require": {
        "php": ">=8.1",
        "yiisoft/yii2": "~2.0.49"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "app\\": ""
        }
    },
    "config": {
        "process-timeout": 1800,
        "allow-plugins": {
            "yiisoft/yii2-composer": true
        }
    },
    "extra": {
        "yii\\composer\\Installer::postUpdate": [
            "yii\\composer\\Installer::setPermission"
        ],
        "writable": [
            "runtime",
            "web/assets"
        ]
    }
}
